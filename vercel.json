{
  "buildCommand": "cd issue-tracker-frontend && npm install && npm run build",
  "outputDirectory": "issue-tracker-frontend/dist/issue-tracker-frontend/browser",
  "framework": "angular",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
